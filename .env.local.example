# Copy this file to .env.local and fill in your real Stripe test keys.
# .env.local is git-ignored — never commit real keys.
#
# Get these from https://dashboard.stripe.com/test/apikeys (use TEST mode
# keys, starting with pk_test_/sk_test_, until you're ready to go live).

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Added once you set up the webhook (see PROJECT_BRIEF.md / connect-stripe
# skill step 8). Run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# locally to get a webhook secret for testing.
STRIPE_WEBHOOK_SECRET=whsec_...

# Used to build absolute success/cancel URLs if "origin" isn't available.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
